# Copy to .env and fill in values from your Supabase project (Settings → API).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_PUBLIC_APP_URL=https://your-production-domain.example

# Optional overrides (defaults match migrations)
VITE_SUPABASE_STATE_TABLE=loadout_states
VITE_SUPABASE_STATE_PROFILE=default
